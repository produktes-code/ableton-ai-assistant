{
  "name": "antigravity-app",
  "version": "1.0.0",
  "description": "Asistente de IA para Ableton Live",
  "author": "produktes-code",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.antigravity.assistant",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.music"
    },
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "puppeteer": "^25.3.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "electron": "^31.0.0",
    "electron-builder": "^26.15.3",
    "jest": "^30.4.2",
    "jsdom": "^29.1.1"
  }
}
